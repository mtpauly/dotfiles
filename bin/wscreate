#!/usr/bin/env bash
# wscreate - Create a new workspace from a template
#
# This script creates isolated workspaces from template directories. Templates are typically
# git repos that serve as starting points for new work sessions.
#
# Filesystem structure:
#   ~/workspace_templates/   - Contains template directories (e.g., repos to clone from)
#   ~/workspaces/            - Contains created workspaces named as {template}_{name}
#
# Usage: wscreate <template_name> <workspace_name>

set -eu

if [[ -z "${TEMPLATE_DIR:-}" ]]; then
    echo "Error: TEMPLATE_DIR environment variable is not set"
    exit 1
fi
if [[ -z "${WORKSPACE_DIR:-}" ]]; then
    echo "Error: WORKSPACE_DIR environment variable is not set"
    exit 1
fi

mkdir -p "$TEMPLATE_DIR"
mkdir -p "$WORKSPACE_DIR"

# Show help if --help flag
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    echo "Usage: wscreate [template_name] [workspace_name]"
    echo ""
    echo "Create a new workspace from a template and start a tmux session."
    echo "If no arguments provided, shows an interactive picker."
    echo ""
    echo "Arguments:"
    echo "  template_name    Name of the template in ~/workspace_templates/"
    echo "  workspace_name   Name for the new workspace (will be prefixed with template name)"
    echo ""
    echo "Available templates:"
    if [ -d "$TEMPLATE_DIR" ] && [ "$(ls -A "$TEMPLATE_DIR" 2>/dev/null)" ]; then
        ls -1 "$TEMPLATE_DIR" | sed 's/^/  /'
    else
        echo "  (none found)"
    fi
    exit 0
fi

# Interactive mode if no arguments provided
if [ $# -lt 2 ]; then
    # Check if any templates exist
    if [ ! -d "$TEMPLATE_DIR" ] || [ -z "$(ls -A "$TEMPLATE_DIR" 2>/dev/null)" ]; then
        echo "No templates found in $TEMPLATE_DIR"
        exit 1
    fi

    # Pick template with fzf
    TEMPLATE_NAME=$(ls -1 "$TEMPLATE_DIR" | fzf --prompt="Select template: ")
    if [ -z "$TEMPLATE_NAME" ]; then
        exit 1
    fi

    # Prompt for workspace name
    echo -n "Workspace name: "
    read -r WORKSPACE_NAME_BASE
    if [ -z "$WORKSPACE_NAME_BASE" ]; then
        echo "Error: Workspace name cannot be empty"
        exit 1
    fi
else
    TEMPLATE_NAME="$1"
    WORKSPACE_NAME_BASE="$2"
fi

WORKSPACE_NAME="${TEMPLATE_NAME}_${WORKSPACE_NAME_BASE}"
# Important: must match the session name generated by tmux-sessionizer
SESSION_NAME="workspaces/$WORKSPACE_NAME"
TEMPLATE_PATH="$TEMPLATE_DIR/$TEMPLATE_NAME"
WORKSPACE_PATH="$WORKSPACE_DIR/$WORKSPACE_NAME"

# Check that template exists and workspace doesn't
if [ ! -d "$TEMPLATE_PATH" ]; then
    echo "Error: Template \"$TEMPLATE_NAME\" does not exist in $TEMPLATE_DIR"
    exit 1
fi
if [ -d "$WORKSPACE_PATH" ]; then
    echo "Error: Workspace \"$WORKSPACE_NAME\" already exists in $WORKSPACE_DIR"
    exit 1
fi

# Create the workspace
echo "Creating workspace for template \"$TEMPLATE_NAME\" at $WORKSPACE_NAME"

# TODO: Should optimize this to make it as fast as possible. Have already tried cloning from local
# instance and it was slower and ext4 doesn't support COW. One good option could be to have a copy
# staged at all times and just move that (then create a new copy in the background).
# TODO: Can we time this operation?
cp -r "$TEMPLATE_PATH" "$WORKSPACE_PATH"

# If tmux isn't running, start it with the new session attached
if [[ -z ${TMUX:-} ]]; then
    tmux new-session -A -s "$SESSION_NAME" -c "$WORKSPACE_PATH"
    exit 0
fi

# Otherwise attach the current client
tmux new-session -d -s "$SESSION_NAME" -c "$WORKSPACE_PATH"
tmux switch-client -t "$SESSION_NAME"

# TODO: Should have some mechanism to keep the template repos up to date. Do it here in the
# background or as a continuously running job?

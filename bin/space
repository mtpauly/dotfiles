#!/usr/bin/env python3
"""space - workspace manager

Manages isolated workspaces created from template directories. Templates are typically
git repos that serve as starting points for new work sessions. Each workspace is a full
copy of a template, with its own tmux session.

Filesystem structure:
  ~/workspace_templates/   - Template directories (source repos to clone from)
  ~/workspaces/            - Created workspaces, named as {template}_{name}
  ~/workspaces/.staged/    - Pre-copied templates for fast workspace creation

Actions:
  create  - Pick a template, name the workspace, copy it, and open a tmux session
  delete  - Pick a workspace, check for unsaved work, and remove it
  update  - Pull latest changes in all template directories

Usage:
  space              - Interactive mode: pick an action via fzf
  space create       - Skip the action picker and go straight to create
  space delete       - Skip the action picker and go straight to delete
  space update       - Skip the action picker and go straight to update

Environment variables (set in .zshrc):
  TEMPLATE_DIR       - Path to template directories (default: ~/workspace_templates)
  WORKSPACE_DIR      - Path to workspace directories (default: ~/workspaces)

Tmux session names are formatted as "workspaces/{workspace_name}" to match the naming
convention used by tmux-sessionizer.
"""

import os
import subprocess
import shutil
import sys


TEMPLATE_DIR = os.environ.get("TEMPLATE_DIR")
WORKSPACE_DIR = os.environ.get("WORKSPACE_DIR")
STAGED_DIR = os.path.join(WORKSPACE_DIR, ".staged") if WORKSPACE_DIR else None
# Set via tmux.conf to pause before exiting so errors are visible
EPHEMERAL_PANE = os.environ.get("SPACE_EPHEMERAL") == "1"


def pause():
    """Pause before exiting so the user can read the output in an ephemeral tmux pane."""
    if EPHEMERAL_PANE:
        input("\nPress enter to continue...")


def exit_with_error(msg: str, code: int = 1):
    print(msg)
    pause()
    sys.exit(code)


def fzf(options: list[str], prompt: str = "") -> str | None:
    """Run fzf with the given options and return the selected option."""
    result = subprocess.run(
        ["fzf", "--prompt", prompt],
        input="\n".join(options),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return None
    return result.stdout.strip()


def staged_path_for(template: str) -> str:
    return os.path.join(STAGED_DIR, template)


def restage_in_background(template: str):
    """Kick off a background process to copy the template to the staged directory."""
    template_path = os.path.join(TEMPLATE_DIR, template)
    staged = staged_path_for(template)
    # Use a subshell so we don't block. Remove any stale staged copy first.
    subprocess.Popen(
        f'rm -rf "{staged}" && cp -r "{template_path}" "{staged}"',
        shell=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def create():
    os.makedirs(TEMPLATE_DIR, exist_ok=True)
    os.makedirs(WORKSPACE_DIR, exist_ok=True)
    os.makedirs(STAGED_DIR, exist_ok=True)

    templates = os.listdir(TEMPLATE_DIR)
    if not templates:
        exit_with_error(f"No templates found in {TEMPLATE_DIR}")

    template = fzf(sorted(templates), prompt="Select template: ")
    if not template:
        sys.exit(1)
    print(f"[space] template: {template}")

    name = input("Workspace name: ").strip()
    if not name:
        exit_with_error("Error: Workspace name cannot be empty")

    workspace_name = f"{template}_{name}"
    # Important: must match the session name generated by tmux-sessionizer
    session_name = f"workspaces/{workspace_name}"
    template_path = os.path.join(TEMPLATE_DIR, template)
    workspace_path = os.path.join(WORKSPACE_DIR, workspace_name)

    if not os.path.isdir(template_path):
        exit_with_error(f'Error: Template "{template}" does not exist in {TEMPLATE_DIR}')
    if os.path.exists(workspace_path):
        exit_with_error(f'Error: Workspace "{workspace_name}" already exists in {WORKSPACE_DIR}')

    staged = staged_path_for(template)
    if os.path.isdir(staged):
        print(f'Creating workspace from staged copy (fast)')
        os.rename(staged, workspace_path)
        restage_in_background(template)
    else:
        print(f'No staged copy available, copying template (this may take a moment)...')
        subprocess.run(["cp", "-r", template_path, workspace_path])
        # Stage a copy for next time
        restage_in_background(template)

    tmux_in_session = os.environ.get("TMUX")
    if not tmux_in_session:
        os.execlp("tmux", "tmux", "new-session", "-A", "-s", session_name, "-c", workspace_path)
    else:
        subprocess.run(["tmux", "new-session", "-d", "-s", session_name, "-c", workspace_path])
        subprocess.run(["tmux", "switch-client", "-t", session_name])


def delete():
    workspaces = [w for w in os.listdir(WORKSPACE_DIR) if w != ".staged"]
    if not workspaces:
        exit_with_error("No workspaces to delete", code=0)

    workspace = fzf(sorted(workspaces), prompt="Select workspace: ")
    if not workspace:
        sys.exit(1)

    workspace_path = os.path.join(WORKSPACE_DIR, workspace)
    # Important: must match the session name generated by tmux-sessionizer
    session_name = f"workspaces/{workspace}"

    # Check for warnings
    warnings = []

    # Check for active tmux session
    if subprocess.run(["tmux", "has-session", "-t", session_name], capture_output=True).returncode == 0:
        warnings.append("⚠️  tmux session exists")

    git_dir = os.path.join(workspace_path, ".git")
    if os.path.isdir(git_dir):
        # Check for uncommitted changes
        result = subprocess.run(["git", "-C", workspace_path, "status", "--porcelain"], capture_output=True, text=True)
        if result.stdout.strip():
            warnings.append("⚠️  Uncommitted changes detected!")

        # Check for unpushed commits
        upstream = subprocess.run(["git", "-C", workspace_path, "rev-parse", "--abbrev-ref", "@{u}"], capture_output=True)
        if upstream.returncode == 0:
            unpushed = subprocess.run(["git", "-C", workspace_path, "log", "@{u}..HEAD", "--oneline"], capture_output=True, text=True)
            if unpushed.stdout.strip():
                warnings.append("⚠️  Unpushed commits detected!")
        else:
            warnings.append("⚠️  Branch has no upstream (not pushed yet?)")

    if warnings:
        print()
        for w in warnings:
            print(w)
        reply = input(f"\nAre you sure you want to delete '{workspace}'? [y/N] ").strip()
        if reply.lower() != "y":
            print("Deletion cancelled.")
            sys.exit(0)

    shutil.rmtree(workspace_path)

    # Kill tmux session if it exists
    if subprocess.run(["tmux", "has-session", "-t", session_name], capture_output=True).returncode == 0:
        subprocess.run(["tmux", "kill-session", "-t", session_name])
        print(f"Successfully deleted workspace {workspace} and killed tmux session")
    else:
        print(f"Successfully deleted workspace {workspace}")

    pause()


def update():
    templates = os.listdir(TEMPLATE_DIR)
    if not templates:
        exit_with_error(f"No templates found in {TEMPLATE_DIR}")

    print("Updating workspace templates...\n")

    for template in sorted(templates):
        template_path = os.path.join(TEMPLATE_DIR, template)
        git_dir = os.path.join(template_path, ".git")

        if not os.path.isdir(git_dir):
            print(f"⏭️  {template} (not a git repo, skipping)")
            continue

        print(f"📦 {template}")

        fetch = subprocess.run(["git", "-C", template_path, "fetch", "--quiet"], capture_output=True)
        if fetch.returncode != 0:
            print("   ❌ fetch failed")
            continue

        local = subprocess.run(["git", "-C", template_path, "rev-parse", "HEAD"], capture_output=True, text=True)
        upstream = subprocess.run(["git", "-C", template_path, "rev-parse", "@{u}"], capture_output=True, text=True)

        if local.stdout.strip() == upstream.stdout.strip():
            print("   ✅ already up to date")
        else:
            pull = subprocess.run(["git", "-C", template_path, "pull", "--quiet"], capture_output=True)
            if pull.returncode == 0:
                print("   ✅ updated")
            else:
                print("   ❌ pull failed (possibly uncommitted changes)")

    # Restage all templates since they may have changed
    print("\nRestaging templates...")
    os.makedirs(STAGED_DIR, exist_ok=True)
    for template in sorted(templates):
        template_path = os.path.join(TEMPLATE_DIR, template)
        if os.path.isdir(template_path):
            staged = staged_path_for(template)
            if os.path.exists(staged):
                shutil.rmtree(staged)
            subprocess.run(["cp", "-r", template_path, staged])

    print("Done!")
    pause()


def main():
    if not TEMPLATE_DIR:
        exit_with_error("Error: TEMPLATE_DIR environment variable is not set")
    if not WORKSPACE_DIR:
        exit_with_error("Error: WORKSPACE_DIR environment variable is not set")

    actions = ["create", "delete", "update"]

    if len(sys.argv) > 1 and sys.argv[1] in actions:
        action = sys.argv[1]
    else:
        action = fzf(actions, prompt="Action: ")
        if not action:
            sys.exit(1)

    print(f"[space] action: {action}")

    if action == "create":
        create()
    elif action == "delete":
        delete()
    elif action == "update":
        update()


if __name__ == "__main__":
    main()

